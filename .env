# User configuration (must match host user on Linux for proper file permissions)
# On Mac, these don't affect permissions but are kept for compatibility
UID=1000
GID=1000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=${APP_NAME}_development

# Rails
DATABASE_URL=postgres://postgres:password@postgres:5432/${APP_NAME}_development
REDIS_URL=redis://redis:6379/0
